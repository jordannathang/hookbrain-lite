from flask import Flask, request, jsonify
import os
import anthropic

app = Flask(__name__)

client = anthropic.Anthropic(
    api_key=os.environ.get("ANTHROPIC_API_KEY")
)

def score_hook(hook):
    score = {
        "watch_signal": len(hook) > 40,
        "emotional_trigger": any(word in hook.lower() for word in ["secret", "shocking", "crazy", "never"]),
        "curiosity_gap": "?" in hook or "..." in hook,
        "retention": len(hook.split()) < 15,
        "clarity": True
    }
    return score

@app.route("/analyze", methods=["POST"])
def analyze():
    data = request.json
    hook = data.get("hook")

    scores = score_hook(hook)

    prompt = f"""
    Rewrite this hook in 5 different ways optimized for virality:
    {hook}
    """

    response = client.messages.create(
        model="claude-3-haiku-20240307",
        max_tokens=300,
        messages=[{"role": "user", "content": prompt}]
    )

    rewrites = response.content[0].text

    return jsonify({
        "scores": scores,
        "rewrites": rewrites
    })

if __name__ == "__main__":
    app.run()
